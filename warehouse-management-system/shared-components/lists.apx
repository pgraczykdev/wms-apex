list administration-sections (
    name: Administration Sections

    entry log-settings (
        label: Log Settings
        icon {
            imageIconCssClasses: fa-sliders
        }
        layout {
            sequence: 20
        }
        link {
            target: {
                page: 9010
            }
        }
        userDefinedAttributes {
            3: LS
            7: Change the Log Settings
        }
    )

    entry logs (
        label: Logs
        icon {
            imageIconCssClasses: fa-list-alt
        }
        layout {
            sequence: 10
        }
        link {
            target: {
                page: 9005
            }
        }
        userDefinedAttributes {
            3: L
            7: View and search application log entries
        }
    )

    entry process-controller (
        label: Process Controller
        icon {
            imageIconCssClasses: fa-tasks
        }
        layout {
            sequence: 30
        }
        link {
            target: {
                page: 9015
            }
        }
        userDefinedAttributes {
            3: PC
            7: Run, stop, and monitor background processes
        }
    )

)

list navigation-bar (
    name: Navigation Bar

    entry app-user (
        label: &APP_USER.
        icon {
            imageIconCssClasses: fa-user
        }
        layout {
            sequence: 10
        }
        link {
            target: {
                type: url
                url: #
            }
        }
        userDefinedAttributes {
            2: has-username
        }
    )

    entry list_item (
        label: ---
        layout {
            sequence: 20
            parentEntry: @app-user
        }
        link {
            target: {
                type: url
                url: separator
            }
        }
        serverSideCondition {
            type: userIsAuthenticated
        }
    )

    entry sign-out (
        label: Sign Out
        icon {
            imageIconCssClasses: fa-sign-out
        }
        layout {
            sequence: 30
            parentEntry: @app-user
        }
        link {
            target: {
                type: url
                url: &LOGOUT_URL.
            }
        }
        serverSideCondition {
            type: userIsAuthenticated
        }
    )

)

list navigation-menu (
    name: Navigation Menu

    entry administration (
        label: Administration
        icon {
            imageIconCssClasses: fa-cogs
        }
        layout {
            sequence: 90
        }
        link {
            target: {
                page: 9000
            }
        }
    )

    entry home (
        label: Home
        icon {
            imageIconCssClasses: fa-home
        }
        layout {
            sequence: 10
        }
        link {
            target: {
                page: 1
            }
        }
    )

    entry log-settings (
        label: Log Settings
        icon {
            imageIconCssClasses: fa-sliders
        }
        layout {
            sequence: 20
            parentEntry: @administration
        }
        link {
            target: {
                page: 9010
            }
        }
    )

    entry logs (
        label: Logs
        icon {
            imageIconCssClasses: fa-list-alt
        }
        layout {
            sequence: 10
            parentEntry: @administration
        }
        link {
            target: {
                page: 9005
            }
        }
    )

    entry process-controller (
        label: Process Controller
        icon {
            imageIconCssClasses: fa-tasks
        }
        layout {
            sequence: 30
            parentEntry: @administration
        }
        link {
            target: {
                page: 9015
            }
        }
    )

)

