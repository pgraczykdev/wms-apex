lov boolean (
    name: BOOLEAN
    source {
        location: staticValues
    }

    entry false (
        sequence: 2
        display: No
        return: FALSE
    )

    entry true (
        sequence: 1
        display: Yes
        return: TRUE
    )

)

lov log-level (
    name: LOG_LEVEL
    source {
        location: staticValues
    }

    entry apex (
        sequence: 90
        display: Apex
        return: APEX
    )

    entry debug (
        sequence: 60
        display: Debug
        return: DEBUG
    )

    entry error (
        sequence: 30
        display: Error
        return: ERROR
    )

    entry information (
        sequence: 50
        display: Information
        return: INFORMATION
    )

    entry off (
        sequence: 10
        display: Off
        return: OFF
    )

    entry permanent (
        sequence: 20
        display: Permanent
        return: PERMANENT
    )

    entry sys-context (
        sequence: 80
        display: Sys Context
        return: SYS_CONTEXT
    )

    entry timing (
        sequence: 70
        display: Timing
        return: TIMING
    )

    entry warning (
        sequence: 40
        display: Warning
        return: WARNING
    )

)

