{
  "project" : "wms-apex",
  "sqlcl" : {
    "connectionName" : "WMS_LIQUIBASE",
    "autoConnect" : false,
    "version" : "26.2.0.0"
  },
  "schemas" : [ "WMS_LIQUIBASE", "WMS_APP", "WMS_APP_PROC", "WMS_LOG", "WMS_LOG_PROC", "WMS_APEX" ],
  "lastReleaseVersion" : "0.0.2.1",
  "apex" : {
    "apexlang" : false
  },
  "export" : {
    "format" : {
      "enable" : true
    },
    "setTransform" : {
      "collationClause" : "NEVER",
      "constraints" : true,
      "constraintsAsAlter" : true,
      "emitSchema" : true,
      "force" : true,
      "partitioning" : false,
      "segmentAttributes" : false,
      "sizeByteKeyword" : true,
      "sqlterminator" : true,
      "storage" : false,
      "tablespace" : false
    },
    "apex" : {
      "exptype" : [ "APEXLANG", "APPLICATION_SOURCE" ],
      "expAclAssignments" : false,
      "expComments" : false,
      "skipExportDate" : true,
      "expirNotif" : false,
      "expOriginalIds" : false,
      "expSavedReports" : false,
      "expPubReports" : true,
      "expSubscriptions" : false,
      "expSupportingObjects" : "N",
      "expTranslations" : false,
      "auditType" : "NULL"
    }
  },
  "git" : {
    "protectedBranches" : [ "main", "master" ],
    "defaultBranch" : "main"
  },
  "stage" : {
    "excludeObjects" : [ "ALL.user" ],
    "generatedFormat" : "liquibase",
    "softObjectIsolation" : "change",
    "substituteSchemas" : false
  }
}